{
  "name": "flowform-studio",
  "version": "0.2.0",
  "private": true,
  "description": "A visual studio for forms, approvals, and collaborative workflows",
  "license": "PolyForm-Noncommercial-1.0.0",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "db:generate": "pnpm --filter @flowform/api prisma:generate",
    "db:migrate": "pnpm --filter @flowform/api prisma:migrate",
    "db:migrate:deploy": "pnpm --filter @flowform/api prisma:migrate:deploy",
    "dev": "pnpm build:packages && turbo run dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @flowform/web test:e2e",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0"
  }
}
